# Copy to .env — use the exact same DATABASE_URL as openchat (one shared Postgres DB).

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# 64 hex chars (32 bytes / 256-bit). Generate: openssl rand -hex 32 — same value in openchat .env
CHAT_INTERNAL_SECRET=your_64_hex_chars_from_openssl_rand_hex_32

# Local: 3003. PaaS: leave unset and use PORT from the host.
CHAT_PORT=3003

# Bind 0.0.0.0 on Railway/Render (default). For local-only: LISTEN_HOST=127.0.0.1
# LISTEN_HOST=0.0.0.0

# In openchat .env set (same host/port as this service):
# CHAT_BROADCAST_URL=http://127.0.0.1:3003/broadcast-unsent
