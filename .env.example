# Copy to .env — use the exact same DATABASE_URL as openchat (one shared Postgres DB).

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# 64 hex chars (32 bytes / 256-bit). Generate: openssl rand -hex 32 — same value in openchat .env
CHAT_INTERNAL_SECRET=your_64_hex_chars_from_openssl_rand_hex_32

# Socket.IO — openchat src/hooks/use-socket.ts uses http://localhost:3003 when NEXT_PUBLIC_SOCKET_URL is unset (local dev)
CHAT_PORT=3003

# HTTP broadcast for “unsent” — openchat src/app/api/messages/route.ts default: http://127.0.0.1:3004/broadcast-unsent
CHAT_BROADCAST_PORT=3004
